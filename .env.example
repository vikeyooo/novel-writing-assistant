# 小说创意助手 v2.0.0 - 配置文件

# ========================================
# DeepSeek API 配置 (必需)
# ========================================
DEEPSEEK_API_KEY=sk_your_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# DeepSeek 模型参数
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=4000
DEEPSEEK_TOP_P=0.95
DEEPSEEK_FREQUENCY_PENALTY=0.0
DEEPSEEK_PRESENCE_PENALTY=0.0

# 思考模式 (DeepSeek V4 特性)
DEEPSEEK_ENABLE_REASONING=true
DEEPSEEK_REASONING_DEPTH=medium

# ========================================
# 联网搜索配置 (可选)
# ========================================
SEARCH_ENGINE=duckduckgo
SEARCH_API_KEY=

# Google 搜索 (可选)
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Bing 搜索 (可选)
BING_SEARCH_ENDPOINT=https://api.cognitive.microsoft.com/bing/v7.0/search

# ========================================
# 本地数据配置
# ========================================
DATA_DIR=./data
NOVEL_DIR=./data/novel
CHAPTERS_DIR=./data/novel/chapters
SEARCH_CACHE_DIR=./data/search_cache
LOG_DIR=./data/logs
BACKUP_DIR=./data/backups

# ========================================
# 日志配置
# ========================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_ROTATION=500MB
LOG_RETENTION=7

# ========================================
# 应用设置
# ========================================
APP_NAME=小说创意助手
APP_VERSION=2.0.0
APP_MODE=cli

# 功能开关
ENABLE_WEB_SEARCH=true
ENABLE_CONSISTENCY_CHECK=true
ENABLE_AUTO_SUGGEST=true
ENABLE_STREAMING=true
ENABLE_CACHING=true

# 缓存设置
CACHE_SEARCH_RESULTS=true
CACHE_TTL=86400
CACHE_SIZE_LIMIT=1000

# ========================================
# 网络配置
# ========================================
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=2
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ========================================
# 高级设置
# ========================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
DEBUG=false
VERBOSE=false

# 批处理
BATCH_SIZE=10
CONCURRENCY_LIMIT=5

# Windows 特定配置
WINDOWS_ENCODING=utf-8
WINDOWS_USE_WINSOUND=true
